# ──────────────────────────────────────────────
# ParentKin — Environment Variables
# Copy this file to .env.local and fill in real values
# ──────────────────────────────────────────────

# OpenAI (required — for coaching advice, embeddings, transcription)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_CHAT_MINI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Upstash Redis (required — for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Supabase (required — auth, family sharing, cloud sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin password (for /admin page)
ADMIN_PASSWORD=your-admin-password

# Public URL (used for metadataBase in SEO/OG tags)
NEXT_PUBLIC_URL=https://parenting-coach-two.vercel.app

# Google Gemini (future use — not yet integrated)
# GEMINI_API_KEY=your-gemini-key-here
